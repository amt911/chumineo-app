{
  "$schema": "https://turbo.build/schema.json",
  "globalPassThroughEnv": [
    "ALLOWED_DEV_ORIGINS",
    "WITH_TAILSCALE",
    "WEB_PORT",
    "API_PORT",
    "NEXT_PUBLIC_API_URL",
    "WEB_PUBLIC_URL",
    "CORS_ORIGINS",
    "API_INTERNAL_URL",
    "API_PROXY_TARGET"
  ],
  "tasks": {
    "build": { "dependsOn": ["^build"], "outputs": ["dist/**", ".next/**"] },
    "dev": { "cache": false, "persistent": true },
    "lint": {},
    "type-check": { "dependsOn": ["^build"] },
    "test": { "dependsOn": ["^build"] },
    "test:cov": { "dependsOn": ["^build"] }
  }
}
