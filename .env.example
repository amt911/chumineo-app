# Copy to .env (cp .env.example .env). These are the canonical single-machine
# defaults. To run alongside another stack (e.g. route-page-app on the same
# ports), shift every *_PORT / *_HOST_PORT here and update DATABASE_URL,
# REDIS_URL and NEXT_PUBLIC_API_URL to match. docker-compose reads the *_HOST_PORT
# vars; the api reads API_PORT; the web launcher reads WEB_PORT.

# Postgres
POSTGRES_USER=sobrebox
POSTGRES_PASSWORD=sobrebox
POSTGRES_DB=sobrebox
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql://sobrebox:sobrebox@localhost:5432/sobrebox?schema=public

# Redis
REDIS_HOST_PORT=6379
REDIS_URL=redis://localhost:6379

# Mailpit (dev mail sink)
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# API
API_PORT=3000

# Web
WEB_PORT=3001
# Tailnet origins for mobile dev over Tailscale; set by the dev:tailscale /
# dev:docker:tailscale scripts (auto-detected). Empty = local-only.
ALLOWED_DEV_ORIGINS=
# Server-side (RSC) API base + the target Next proxies same-origin /api/* to.
# Client code calls /api (proxied via next.config rewrites) so it works from any
# device (e.g. a phone over Tailscale) without CORS or resolving localhost.
API_INTERNAL_URL=http://localhost:3000
API_PROXY_TARGET=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:3000

# Auth
JWT_ACCESS_SECRET=changeme-access
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL_DAYS=7
JWT_REFRESH_REMEMBER_DAYS=30
LOCKOUT_MAX_ATTEMPTS=5
LOCKOUT_WINDOW_MIN=15
NODE_ENV=development

# Mail
MAIL_TRANSPORT=smtp
MAIL_SMTP_HOST=localhost
MAIL_SMTP_PORT=1025
MAIL_FROM=no-reply@sobrebox.local
RESEND_API_KEY=

# Web ↔ API
WEB_PUBLIC_URL=http://localhost:3001
CORS_ORIGINS=http://localhost:3001

# ──────────────────────────────────────────────────────────────────────────
# Production (Coolify) — set these per service in the Coolify UI, NOT in git.
# See docs/DEPLOY.md.
#
# api (internal service):
#   NODE_ENV=production
#   API_PORT=3000
#   DATABASE_URL=postgresql://<user>:<pwd>@<coolify-postgres-host>:5432/<db>
#   REDIS_URL=redis://<coolify-redis-host>:6379        # add :<pwd>@ if required
#   JWT_ACCESS_SECRET=<long-random-secret>             # MUST override the dev default
#   JWT_ACCESS_TTL=15m
#   JWT_REFRESH_TTL_DAYS=7
#   JWT_REFRESH_REMEMBER_DAYS=30
#   LOCKOUT_MAX_ATTEMPTS=5
#   LOCKOUT_WINDOW_MIN=15
#   MAIL_TRANSPORT=resend
#   RESEND_API_KEY=<resend-key>
#   MAIL_FROM=<verified-resend-sender>
#   WEB_PUBLIC_URL=https://<coolify-web-temp-domain>   # email verification links
#   CORS_ORIGINS=https://<coolify-web-temp-domain>
#
# web (public service):
#   NODE_ENV=production
#   PORT=3000
#   HOSTNAME=0.0.0.0
#   API_INTERNAL_URL=http://<coolify-api-internal-host>:3000
#   API_PROXY_TARGET=http://<coolify-api-internal-host>:3000
# ──────────────────────────────────────────────────────────────────────────
