# Copy to .env (cp .env.example .env). These are the canonical single-machine
# defaults. To run alongside another stack (e.g. route-page-app on the same
# ports), shift every *_PORT / *_HOST_PORT here and update DATABASE_URL,
# REDIS_URL and NEXT_PUBLIC_API_URL to match. docker-compose reads the *_HOST_PORT
# vars; the api reads API_PORT; the web launcher reads WEB_PORT.

# Postgres
POSTGRES_USER=sobrebox
POSTGRES_PASSWORD=sobrebox
POSTGRES_DB=sobrebox
POSTGRES_HOST_PORT=5432
DATABASE_URL=postgresql://sobrebox:sobrebox@localhost:5432/sobrebox?schema=public

# Redis
REDIS_HOST_PORT=6379
REDIS_URL=redis://localhost:6379

# Mailpit (dev mail sink)
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# API
API_PORT=3000
JWT_SECRET=changeme

# Web
WEB_PORT=3001
NEXT_PUBLIC_API_URL=http://localhost:3000
